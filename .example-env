# =========================
# Application Configuration
# =========================

APP_PORT=:8080
APP_ENV=development

# Comma-separated list of browser origins allowed to call the API with cookies.
# Must include the frontend dev URL exactly (scheme + host + port). Use "*" for
# any origin in local dev only (never with real credentials in production).
CORS_ALLOWED_ORIGINS=http://localhost:3000


# =========================
# MySQL Configuration
# =========================

MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=drexa
MYSQL_USER=drexa_user
MYSQL_PASSWORD=change_me_password

# "mysql" = Docker service name. Change to "localhost" for local dev without Docker.
DB_DSN=drexa_user:change_me_password@tcp(mysql:3306)/drexa?parseTime=true

DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=100
DB_CONN_MAX_LIFETIME=1h


# =========================
# Redis Configuration
# =========================

# "redis" = Docker service name. Change to "localhost" for local dev without Docker.
REDIS_ADDR=redis:6379
REDIS_PASSWORD=change_me_redis
REDIS_DB=0


# =========================
# JWT Configuration
# =========================

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRATION=24h


# =========================
# Firebase Configuration
# =========================

# Base64-encoded Firebase service account JSON.
# 1. Firebase Console → Project Settings → Service Accounts → Generate New Private Key
# 2. Linux/Mac:  base64 -w 0 service-account.json
#    Windows:    [Convert]::ToBase64String([IO.File]::ReadAllBytes("service-account.json"))
FIREBASE_CREDENTIALS_JSON=
FIREBASE_PROJECT_ID=your-firebase-project-id


# =========================
# Twilio Configuration
# =========================

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_PHONE=+1234567890


# =========================
# Email Configuration
# =========================
# Resend is the primary email provider. When RESEND_API_KEY is set it takes
# precedence; otherwise the server falls back to SendGrid (below).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=Drexa

# SendGrid (fallback — used only when RESEND_API_KEY is empty)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=Drexa
APP_URL=http://localhost:3000


# =========================
# Stripe Configuration
# =========================

# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
# Publishable key — must match NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY in the frontend.
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx
# Webhook signing secret — shown after you create the webhook endpoint, or printed
# by `stripe listen --forward-to localhost:8080/api/v1/payments/webhook`.
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx


# =========================
# PayPal Configuration (withdrawal payouts)
# =========================
# REST app credentials from https://developer.paypal.com/dashboard/applications
# Used for the USD withdrawal payout leg (PayPal Payouts). Deposits use Stripe.
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
# Sandbox (default) or live: https://api-m.paypal.com
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com


# =========================
# Didit Identity Verification (KYC)
# =========================

# From https://business.didit.me → API keys. Leave DIDIT_API_KEY empty to disable
# the hosted KYC flow (the /kyc/didit/* endpoints then return 503).
DIDIT_API_KEY=
DIDIT_WEBHOOK_SECRET=
# Workflow UUID for the KYC flow; defaults to the bundled "Drexa" workflow.
DIDIT_WORKFLOW_ID=3b3ef226-0f3f-49cb-9be6-9fbfc19a0885


# =========================
# P2P On-Chain Escrow (smart contract)
# =========================
# EVM JSON-RPC endpoint. Local Hardhat node: http://127.0.0.1:8545
# Public testnet (Sepolia): your Infura/Alchemy HTTPS URL.
# Leave ESCROW_RPC_URL / ESCROW_CONTRACT_ADDRESS / ESCROW_PRIVATE_KEY empty to
# disable on-chain escrow (P2P escrow endpoints return a "not configured" error).
# ESCROW_RPC_URL=http://127.0.0.1:8545
# # 0 = auto-detect from the node (Hardhat=31337, Sepolia=11155111).
# ESCROW_CHAIN_ID=0
# # Platform signer = the P2PEscrow contract's arbiter (SECRET; never log/expose).
# # Local dev: the Hardhat account #0 test key (no real funds).
# ESCROW_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# # Hardcoded for local dev because the first deployment is deterministic.
# ESCROW_CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
# ESCROW_CONFIRM_TIMEOUT=90s


# ===================
#  NGROK
# ===================
# Toggle the ngrok reverse proxy. Docker Compose reads COMPOSE_PROFILES from
# this file: set it to "ngrok" to start the public tunnel (needed so Tatum/Stripe
# webhooks can reach the local server). Leave it empty to run on localhost only.
COMPOSE_PROFILES=ngrok
NGROK_AUTHTOKEN=
